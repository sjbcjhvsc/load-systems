generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactMessage {
  id           String @id @default(cuid())
  nombre       String
  email        String
  empresa      String?
  mensaje      String
  tipoProyecto String
  presupuesto  String
  status       String @default("nuevo")
  createdAt DateTime @default(now())
}
